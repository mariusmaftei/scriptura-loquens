      "position": 7,
      "references": "Ps. 33:6; Isa. 40:13, 14",
      "segments": [
        {
          "character_name": null,
          "role": "narrator",
          "text": "Pământul era pustiu şi gol; peste faţa adâncului de ape era întuneric, şi* Duhul lui Dumnezeu Se mişca pe deasupra apelor."
        }
      ],
      "verse_num": "2"
    },
    {
      "chunk_type": "verse",
      "position": 8,
      "references": "Ps. 33:9; 2Cor. 4:6",
      "segments": [
        {
          "character_name": null,
          "role": "narrator",
          "text": "Dumnezeu* a zis:"
        },
        {
          "character_name": "Dumnezeu",
          "role": "character",
          "text": "Să fie** lumină!"
        },
        {
          "character_name": null,
          "role": "narrator",
          "text": "Şi a fost lumină."
        }
      ],
      "verse_num": "3"
    },
    {
      "chunk_type": "verse",
      "position": 9,
      "references": null,
      "segments": [
        {
          "character_name": null,
          "role": "narrator",
          "text": "Dumnezeu a văzut că lumina era bună; şi Dumnezeu a despărţit lumina de întuneric."
        }
      ],
      "verse_num": "4"
    },
    {
      "chunk_type": "verse",
      "position": 10,
      "references": "Ps. 74:16; Ps. 104:20",
      "segments": [
        {
          "character_name": null,
          "role": "narrator",
          "text": "Dumnezeu a numit lumina zi, iar întunericul l-a numit noapte. Astfel, a fost o seară, şi apoi a fost o dimineaţă: aceasta a fost ziua întâi."
        }
      ],
      "verse_num": "5"
    },
    {
      "chunk_type": "section_title",
      "position": 11,
      "references": null,
      "segments": [
        {
          "character_name": null,
          "role": "narrator",
          "text": "Cerul"
