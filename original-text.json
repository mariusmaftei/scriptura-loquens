    {
      "chunk_type": "verse",
      "position": 12,
      "references": "Iov 37:18; Ps. 136:5; Ier. 10:12; Ier. 51:15",
      "segments": [
        {
          "character_name": null,
          "role": "narrator",
          "text": "Dumnezeu a zis:"
        },
        {
          "character_name": "Dumnezeu",
          "role": "character",
          "text": "„Să fie o întindere între ape, şi ea să despartă apele de ape.”"
        }
      ],
      "verse_num": "6"
    },
    {
      "chunk_type": "verse",
      "position": 13,
      "references": "Prov. 8:28; Ps. 148:4",
      "segments": [
        {
          "character_name": null,
          "role": "narrator",
          "text": "Şi Dumnezeu a făcut întinderea, şi ea a despărţit apele care sunt dedesubtul întinderii de apele care sunt deasupra întinderii. Şi aşa a fost."
        }
      ],
      "verse_num": "7"
    },
    {
      "chunk_type": "verse",
      "position": 14,
      "references": null,
      "segments": [
        {
          "character_name": null,
          "role": "narrator",
          "text": "Dumnezeu a numit întinderea cer. Astfel, a fost o seară, şi apoi a fost o dimineaţă: aceasta a fost ziua a doua."
        }
      ],
      "verse_num": "8"
    },
    {
      "chunk_type": "section_title",
