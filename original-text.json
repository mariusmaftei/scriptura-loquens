      "references": "Evr. 6:7; Luc. 6:44",
      "segments": [
        {
          "character_name": null,
          "role": "narrator",
          "text": "Apoi Dumnezeu a zis:"
        },
        {
          "character_name": "Dumnezeu",
          "role": "character",
          "text": "„Să dea pământul verdeaţă, iarbă cu sămânţă, pomi roditori, care să facă rod după soiul lor şi care să aibă în ei sămânţa lor pe pământ.”"
