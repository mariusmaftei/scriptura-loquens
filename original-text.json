        {
          "character_name": null,
          "role": "narrator",
          "text": "Dumnezeu a numit uscatul pământ, iar grămada de ape a numit-o mări. Dumnezeu a văzut că lucrul acestaera bun"
        }
      ],
      "verse_num": "10"
