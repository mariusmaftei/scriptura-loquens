SECRET_KEY=your-secret-key-change-in-production
PORT=5000

ADMIN_EMAIL=admin@test.com
ADMIN_PASSWORD=admin1
FRONTEND_URL=http://localhost:3000

DATABASE_URL=sqlite:///scriptura_loquens.db

UPLOAD_FOLDER=uploads
AUDIO_FOLDER=audio

MAX_CONTENT_LENGTH_MB=100
MAX_PDF_PAGES=5

GOOGLE_GEMINI_API_KEY=your-api-key-from-aistudio-google-com
# Or use GEMINI_API_KEY (official env var for google-genai SDK)
GEMINI_MODEL_ID=gemini-2.5-flash

TTS_PROVIDER=edge
TTS_USE_CHIRP_HD=false
ELEVENLABS_API_KEY=your-elevenlabs-api-key

FRONTEND_BUILD=/app/frontend
